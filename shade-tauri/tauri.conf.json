{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "Shade",
  "version": "0.1.0",
  "identifier": "com.tihav.shade",
  "build": {
    "beforeDevCommand": "bunx vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bunx vite build",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shade",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 26
        },
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Pictures/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "iOS": {
      "developmentTeam": "V54JVP5QGU"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
