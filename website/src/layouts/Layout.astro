---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Shade — Professional RAW Editor",
  description = "Professional-grade RAW image processing in the browser. Fast, intuitive, and free of bloat.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#050505] text-[#f5f5f4] antialiased">
    <slot />
  </body>
</html>
